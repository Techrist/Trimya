{
  "expo": {
    "name": "Trimya",
    "slug": "trimya",
    "version": "1.0.0",
    "description": "Application de fidélité pour salons de coiffure — par TON ENTREPRISE",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "trimya",
    "userInterfaceStyle": "dark",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.trimya.mobile",
      "infoPlist": {
        "NSCameraUsageDescription": "Trimya utilise la caméra pour scanner les QR codes des clients fidèles.",
        "NSPhotoLibraryUsageDescription": "Trimya a besoin d'accéder à tes photos pour ajouter une photo de profil aux coiffeurs."
      }
    },
    "android": {
      "package": "app.trimya.mobile",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A0A0A"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.VIBRATE",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Trimya a besoin de la caméra pour scanner les QR codes des clients."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Trimya a besoin d'accéder à tes photos pour ajouter une photo de profil aux coiffeurs."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#FF5722"
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/logo-mark.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0A0A0A",
          "dark": {
            "image": "./assets/logo-mark.png",
            "imageWidth": 200,
            "resizeMode": "contain",
            "backgroundColor": "#0A0A0A"
          }
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "419d4de4-7ecc-4a64-9724-56a92041fecc"
      }
    }
  }
}
